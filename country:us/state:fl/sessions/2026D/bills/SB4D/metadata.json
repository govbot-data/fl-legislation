  "legislative_session": "2026D",
  "identifier": "SB 4D",
  "title": "Public Records/Investigations by the Department of Legal Affairs",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "and solicitations",
