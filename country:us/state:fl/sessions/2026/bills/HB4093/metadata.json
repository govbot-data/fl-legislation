  "abstracts": [
    {
      "note": "summary",
      "abstract": "Fellsmere Water Control District, Indian River County;  Provides that the district is dependent district of Indian River County; provides that the Board of County Commissioners of Indian River County shall be governing board of district; revises boundaries of district; provides for maintenance & use of certain canals; provides for certain access to public records."
    }
  ],
