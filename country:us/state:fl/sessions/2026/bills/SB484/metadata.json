{
  "legislative_session": "2026",
  "identifier": "SB 484",
  "title": "Data Centers",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "public business",
    "railroads and other regulated utilities",
