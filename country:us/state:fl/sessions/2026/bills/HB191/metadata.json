{
  "legislative_session": "2026",
  "identifier": "HB 191",
  "title": "Verification of Reemployment Assistance Benefit Eligibility",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "subject index"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Verification of Reemployment Assistance Benefit Eligibility;  Revises circumstances under which COM disqualifies claimants from reemployment assistance benefits; requires department to verify claimants' identities before paying benefits & to cross-check certain information to verify claimants' eligibility; requires department to maintain web page for specified purpose & to notify employers each year of web page."
    }
  ],
