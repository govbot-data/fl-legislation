  "abstracts": [
    {
      "note": "summary",
      "abstract": "Drug Prices and Coverage ;  Revises definition of term \"pharmacy benefits plan or program\" to exclude plan or program that exclusively serves PACE organization; requires contracts between pharmacy benefit managers & participating pharmacies to allow specified option in administrative appeal procedure; provides pharmacy benefit manager prohibited practices relating to pharmacies & pharmacists."
    }
  ],
