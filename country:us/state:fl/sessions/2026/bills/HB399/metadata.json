{
  "legislative_session": "2026",
  "identifier": "HB 399",
  "title": "Land Use and Development Regulations",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "municipalities",
