{
  "legislative_session": "2026",
  "identifier": "HB 1217",
  "title": "Prohibited Governmental Policies Regulating Greenhouse Gas Emissions",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "municipalities",
    "public business",
    "subject index"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Prohibited Governmental Policies Regulating Greenhouse Gas Emissions;  Prohibits governmental entities from adopting certain net zero policies; prohibits governmental entities from using public funds in any manner that supports, implements, or advances certain net zero policies; prohibits governmental entities from imposing any charge to advance certain net zero policies; requires each governmental entity to annually submit to Department of Revenue certain affidavit; prohibits governmental entities from implementing, administering, or enforcing certain programs."
    }
  ],
