  ],
  "subject": [
    "subject index"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Special Districts;  Provides that boundaries of downtown development district may only be changed in specified manner; requires adopted budget of downtown development district to contain specified information; prohibits certain expenditures from exceeding specified percentage of budget;  requires budget be approved in specified manner; revises agency agreements that provide state financial assistance to recipients or subrecipients to include specified special districts as entity to which such agency may provide for payment of invoices."
    }
  ],
