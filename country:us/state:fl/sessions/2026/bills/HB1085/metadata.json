{
  "legislative_session": "2026",
  "identifier": "HB 1085",
  "title": "Local Government Cyber Security",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "public business"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Local Government Cyber Security;  Creates Local Government Cybersecurity Protection Program within University of South Florida, to be administered by Florida Center for Cybersecurity; requires Florida Center for Cybersecurity to enter into data-sharing agreements with local governments & Florida Digital Service; requires Florida Center for Cybersecurity to administer grant program based on specified criteria to provide information technology commodities & services to local governments; requires Florida Center for Cybersecurity to contract for information technology commodities & services & award such commodities & services to local governments; requires Florida Center for Cybersecurity to prepare & submit specified report to Governor's Office of Policy & Budget & chairs of legislative appropriations committees."
    }
  ],
