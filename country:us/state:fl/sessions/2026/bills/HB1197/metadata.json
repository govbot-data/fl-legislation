  "abstracts": [
    {
      "note": "summary",
      "abstract": "Information Technology Procurement and Contracting;  Revises duties & requirements of Florida Digital Services; creates the Bureau of Enterprise Project Management and Oversight; provides duties & requirements of the bureau; requires state agencies include follow certain processes and use certain forms; requires certain information be included in specified contracts; revises requirements for certain contracts; requires DMS to create a repository for certain records; revises requirements for information technology competitive solicitations."
    }
  ],
