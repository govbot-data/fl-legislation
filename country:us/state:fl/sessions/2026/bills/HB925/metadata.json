  "abstracts": [
    {
      "note": "summary",
      "abstract": "Clerks of the Court;  Authorizing the cumulative excess of funds to be used in the development of the total combined budgets of the clerks of the court; conforming provisions to changes made by the act; revising the definition of the term \u201cpublicly accessible website\u201d; increasing the percentage of certain penalties which must be deposited into the fine and forfeiture fund and decreasing the percentage of certain penalties that must be paid to a municipality, etc."
    }
  ],
