  "abstracts": [
    {
      "note": "summary",
      "abstract": "Clerks of the Court;  Authorizes Florida Clerks of Court Operations Corporation, on behalf of clerks, to submit request for reimbursement to reimburse clerks for filing certain petitions, orders, appeals, & summons; increases rate at which clerks may be reimbursed for filing certain petitions, orders, appeals, & summons; authorizes clerk to be reimbursed for certain fees & charges; increases percentage of certain penalties that must be deposited into fine & forfeiture fund & decreases percentage of certain penalties that must be paid to municipality."
    }
  ],
