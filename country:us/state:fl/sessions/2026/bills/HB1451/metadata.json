{
  "legislative_session": "2026",
  "identifier": "HB 1451",
  "title": "Utility Services",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "municipalities"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Utility Services;  Requires certain public meetings as condition precedent to effectiveness of new or extended agreement under which municipality will provide specified utility services in other municipalities or unincorporated areas; requires municipalities that provide specified utility services to report certain information by specified date, & annually thereafter, to PSC; requires PSC to compile such information & submit report by specified date, & annually thereafter, to Governor & Legislature;  provides for state preemption over subject of certain regional utilities authorities created after specified date."
    }
  ],
