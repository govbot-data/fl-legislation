  "subject": [
    "banks and banking",
    "estates and trusts"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Estates;  Revising the issues a court may resolve for a personal representative; requiring the court to award taxable costs and attorney fees in certain proceedings; authorizing the court to direct such payment from certain persons; revising when summary administration proceedings may commence for either a resident or nonresident decedent\u2019s estate; revising the sum for funds certain financial institutions may make payable to a decedent\u2019s family member, etc."
    }
  ],
