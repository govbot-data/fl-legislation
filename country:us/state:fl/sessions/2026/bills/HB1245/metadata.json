{
  "legislative_session": "2026",
  "identifier": "HB 1245",
  "title": "Biosolids Management",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "public health"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Biosolids Management;  Prohibits land application of Class AA biosolids fertilizer & compost products from exceeding appropriate agronomic rate; requires land application site owners & operators to maintain records; requires DEP to provide certain notice to such owners & operators & to adopt rules; requires University of Florida's IFAS to publish & make publicly available recommended agronomic rates for bulk Class AA biosolids fertilizer & compost products; authorizes bulk Class AA biosolids or biosolids products to be distributed or marketed as fertilizer & land applied if specified requirements are met; authorizes bulk Class AA biosolids compost products to be distributed or marketed as soil amendments & land applied if specified requirements are met; requires that certain bulk Class AA biosolids compost & fertilizer products be applied at certain land application sites; requires certain bulk Class AA products applied on certain lands meet certain requirements before application."
    }
  ],
