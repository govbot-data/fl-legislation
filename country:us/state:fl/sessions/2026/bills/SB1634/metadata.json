  "abstracts": [
    {
      "note": "summary",
      "abstract": "Public Records/Chief of Domestic Security;  Providing an exemption from public records requirements for certain information relating to the designation of an organization as a domestic terrorist organization or a foreign terrorist organization by the Chief of Domestic Security; providing for future legislative review and repeal of the exemption; providing a statement of public necessity, etc."
    }
