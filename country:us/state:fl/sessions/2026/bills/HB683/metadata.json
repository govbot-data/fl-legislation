{
  "legislative_session": "2026",
  "identifier": "HB 683",
  "title": "Performance of Physician Assistants and Advanced Practice Registered Nurses",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "subject index"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Performance of Physician Assistants and Advanced Practice Registered Nurses;  Removes requirement that supervising physician notify DOH in writing of any delegation of prescribing authority to physician assistant; removes requirement that supervising physician's name be included in prescription issued by physician assistant; revises requirements for drug formulary for physician assistants; revises drug formulary requirements for advanced practice registered nurses authorized to prescribe medications; provides exception for psychiatric nurses."
    }
  ],
