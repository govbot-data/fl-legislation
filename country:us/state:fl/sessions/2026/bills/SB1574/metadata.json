  "abstracts": [
    {
      "note": "summary",
      "abstract": "Newborn Screenings;  Citing this act as \u201cMattie\u2019s Law\u201d; requiring that newborns, beginning on a specified date, be screened for biliary atresia; requiring the Department of Health to consult with the Genetics and Newborn Screening Advisory Council before adopting certain rules; requiring hospitals that provide birthing services to screen for biliary atresia in a specified manner, etc."
    }
  ],
