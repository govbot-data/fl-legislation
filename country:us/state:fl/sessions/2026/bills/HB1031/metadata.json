  ],
  "subject": [
    "executive branch"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Customer Service Callback Queues;  Defines \"callback queue\"; establishes pilot program to require the Department of Commerce to use a callback queue for returning certain calls; requires calls to be returned in specified manner and timeframe; requires the department to report specified information to the Legislature by a certain date."
    }
  ],
