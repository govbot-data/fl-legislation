    "subject index"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Pub. Rec./Terrorist Organizations;  Provides exemption from public records requirements for certain information relating to designation of organization as domestic terrorist organization or foreign terrorist organization by Chief of Domestic Security; provides for future legislative review & repeal of exemption; provides statement of public necessity."
    }
