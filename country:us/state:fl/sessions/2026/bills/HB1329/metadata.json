{
  "legislative_session": "2026",
  "identifier": "HB 1329",
  "title": "Local Government Spending",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "municipalities",
    "planning and development",
    "subject index"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Local Government Spending;  Revises length of time tentative budgets & final budgets must be posted on county, municipality, & special district websites; requires posting of such budgets to allow members of public to download & review certain information & data in specified formats; requires county and municipal budget officer to perform certain exercise before final adoption of budget; revises length of time adopted amendment must be posted on county's & municipality's website; requires posting of proposed amendment to meet certain requirements; provides exception for counties & municipalities that meet certain requirements; requires counties & municipalities that meet such exception to provide information in form & manner prescribed by DFS; authorizes counties & municipalities to apply for certain hardship waivers."
    }
  ],
