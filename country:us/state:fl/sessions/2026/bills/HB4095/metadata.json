  "abstracts": [
    {
      "note": "summary",
      "abstract": "Headwaters Water Control District, Indian River County;  Creates Headwaters Water Control District as public corporation; provides district's charter; provides status & boundaries; provides minimum charter requirements; provides for maintenance & use of certain canals; provides requirements for charter amendments; provides applicability of specified laws to district; provides severability."
    }
