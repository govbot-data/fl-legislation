  "abstracts": [
    {
      "note": "summary",
      "abstract": "Biosolids Management ;  Prohibits DEP from issuing or renewing permit for certain biosolids land application sites if there is permitted wastewater treatment facility within specified distance of application site & which meets specified requirements."
    }
