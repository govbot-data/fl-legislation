    "subject index"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Linking Industry to Nursing Education Fund;  Revises Liking Industry to Nursing Education Fund to include nonmonetary contributions; provides requirements for such contributions; revises authorized uses of awarded funds, proposal & review requirements, & allowable contributions; prohibits proposal to participate in fund from being comprised solely of nonmonetary contributions; & authorizes multiyear awards."
    }
  ],
