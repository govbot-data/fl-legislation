  "abstracts": [
    {
      "note": "summary",
      "abstract": "Pub. Rec./Office of Financial Regulation;  Expanding an exemption from public records requirements to include information obtained by Office of Financial Regulation during investigations & examinations relating to virtual currency businesses & payments to stablecoin issuers & to include trust companies that are qualified payment stablecoin issuers in existing protections afforded to other financial institutions."
    }
  ],
