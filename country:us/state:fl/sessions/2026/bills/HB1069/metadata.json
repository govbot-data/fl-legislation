  "abstracts": [
    {
      "note": "summary",
      "abstract": "Background Screenings;  Revises definition of term \"athletic coach\"; provides that independent sanctioning authority is deemed to be qualified entity for purpose of participating in Care Provider Background Screening Clearinghouse; requires qualified entities to designate user administrator for specified purpose; prohibits certain persons from denying or failing to acknowledge certain criminal history records that have been expunged or sealed; requires FDLE to disclose sealed criminal history records."
    }
  ],
