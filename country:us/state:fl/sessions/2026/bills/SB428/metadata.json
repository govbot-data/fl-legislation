{
  "legislative_session": "2026",
  "identifier": "SB 428",
  "title": "Drowning Prevention",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "subject index"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Drowning Prevention;  Revising the purpose of the Swimming Lesson Voucher Program; revising the age requirements for children receiving a voucher through the program; requiring the Department of Health to develop educational materials on drowning prevention safety measures and safe bathing practices for specified purposes; requiring hospitals, birth centers, and home birth providers to provide the educational materials to new parents and caregivers as part of their postpartum education and care, etc."
    }
  ],
