{
  "legislative_session": "2026",
  "identifier": "HB 1503",
  "title": "Computer Science Education and Certification",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "subject index"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Computer Science Education and Certification;  Provides requirements for general education core courses with technology component; requires high school computer science courses to include instruction on artificial intelligence; requires SBE to establish separate computer science subject area coverages for specified grades & to continue comprehensive K\u201312 coverage; requires DOE to present recommended competencies for certain subject area coverages to state board by specified date; requires department to coordinate examinations for such subject area coverages by specified date."
    }
  ],
